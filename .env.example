# ── LLM Providers ──────────────────────────────────────
# Set only the keys for providers you intend to use.
# NOTE: DeepSeek has been removed — it routes traffic to China and is not suitable
#       for a tool that processes internal Zscaler incident logs.

GROQ_API_KEY=gsk_...
OPENROUTER_API_KEY=sk-or-...
OLLAMA_BASE_URL=http://localhost:11434   # or http://ollama:11434 inside Docker

# ── Default provider & model ────────────────────────────
DEFAULT_PROVIDER=groq
DEFAULT_MODEL=llama-3.3-70b-versatile

# ── Qdrant ─────────────────────────────────────────────
QDRANT_HOST=localhost          # use "qdrant" when running inside Docker
QDRANT_PORT=6333
COLLECTION_NAME=zscaler_docs

# ── Embeddings ─────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3   # hybrid dense+sparse (MTEB 64.3 vs 56.3 for MiniLM)
EMBEDDING_DIM=1024
SPARSE_ENABLED=true           # set false to use dense-only (faster, less accurate)

# ── RAG tuning ─────────────────────────────────────────
TOP_K=5
CHUNK_SIZE=1500
CHUNK_OVERLAP=150

# ── Crawl4AI (Docker service) ───────────────────────────
CRAWL4AI_BASE_URL=http://localhost:11235   # or http://crawl4ai:11235 inside Docker

# ── API ────────────────────────────────────────────────
API_KEY=zscaler-rag            # Must match OPENAI_API_KEY in docker-compose.yml
ALLOWED_ORIGINS=http://localhost:3000   # Comma-separated list of allowed CORS origins

# ── RAG quality ─────────────────────────────────────────
MIN_SCORE=0.3                  # Minimum cosine similarity to include a chunk (0–1)
