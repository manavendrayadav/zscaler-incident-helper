# ── LLM Providers ──────────────────────────────────────
# Set only the keys for providers you intend to use.
# NOTE: DeepSeek has been removed — it routes traffic to China and is not suitable
#       for a tool that processes internal Zscaler incident logs.

GROQ_API_KEY=gsk_...
OPENROUTER_API_KEY=sk-or-...
OPENAI_API_KEY=sk-...         # optional; US servers — do not use for internal data
ANTHROPIC_API_KEY=sk-ant-...  # optional; US servers — do not use for internal data
OLLAMA_BASE_URL=http://localhost:11434   # or http://ollama:11434 inside Docker

# ── Default provider & model ────────────────────────────
DEFAULT_PROVIDER=groq
DEFAULT_MODEL=llama-3.3-70b-versatile

# ── Qdrant ─────────────────────────────────────────────
QDRANT_HOST=localhost          # use "qdrant" when running inside Docker
QDRANT_PORT=6333
COLLECTION_NAME=zscaler_docs

# ── Embeddings ─────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-m3   # hybrid dense+sparse (MTEB 64.3 vs 56.3 for MiniLM)
EMBEDDING_DIM=1024
SPARSE_ENABLED=true           # set false to use dense-only (faster, less accurate)

# ── RAG tuning ─────────────────────────────────────────
TOP_K=5
CHUNK_SIZE=1500
CHUNK_OVERLAP=150

# ── Crawl4AI (Docker service) ───────────────────────────
CRAWL4AI_BASE_URL=http://localhost:11235   # or http://crawl4ai:11235 inside Docker

# ── API ────────────────────────────────────────────────
API_KEY=zih-api                 # Must match OPENAI_API_KEY in docker-compose.yml
# OpenWebUI JWT signing secret — generate with: openssl rand -hex 32
WEBUI_SECRET_KEY=change-me-in-production
ALLOWED_ORIGINS=http://localhost:3000   # Comma-separated list of allowed CORS origins

# ── RAG quality ─────────────────────────────────────────
MIN_SCORE=0.3                  # Minimum cosine similarity to include a chunk (0–1)

# ── Platform tweaks ─────────────────────────────────────
# Suppress HuggingFace symlinks warning on Windows (uses full file copies instead).
# Safe to leave enabled on Linux too — has no effect where symlinks work natively.
HF_HUB_DISABLE_SYMLINKS_WARNING=1
# Suppress Python 3.12 multiprocess cleanup noise from FlagEmbedding tokenizer.
# Does not affect embedding quality — only disables parallel pre-tokenization.
TOKENIZERS_PARALLELISM=false
