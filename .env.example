# ── LLM Providers ──────────────────────────────────────
# Set only the keys for providers you intend to use.

GROQ_API_KEY=gsk_...
OPENROUTER_API_KEY=sk-or-...
DEEPSEEK_API_KEY=sk-...
OLLAMA_BASE_URL=http://localhost:11434   # or http://ollama:11434 inside Docker

# ── Default provider & model ────────────────────────────
DEFAULT_PROVIDER=groq
DEFAULT_MODEL=llama-3.3-70b-versatile

# ── Qdrant ─────────────────────────────────────────────
QDRANT_HOST=localhost          # use "qdrant" when running inside Docker
QDRANT_PORT=6333
COLLECTION_NAME=zscaler_docs

# ── Embeddings ─────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ── RAG tuning ─────────────────────────────────────────
TOP_K=5
CHUNK_SIZE=1500
CHUNK_OVERLAP=150

# ── Crawl4AI (Docker service) ───────────────────────────
CRAWL4AI_BASE_URL=http://localhost:11235   # or http://crawl4ai:11235 inside Docker

# ── API ────────────────────────────────────────────────
API_KEY=zscaler-rag            # Must match OPENAI_API_KEY in docker-compose.yml
